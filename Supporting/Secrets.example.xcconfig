//  Secrets.example.xcconfig — TEMPLATE (safe to commit; no real keys here).
//
//  SETUP
//    1. Copy this to `Secrets.xcconfig` (same folder) and fill in the values below:
//         cp Supporting/Secrets.example.xcconfig Supporting/Secrets.xcconfig
//       `Secrets.xcconfig` is gitignored, so your real keys never get committed.
//    2. Wire it once in Xcode:
//         • Project ▸ Info ▸ Configurations ▸ set Debug & Release to `Secrets.xcconfig`
//         • kida target ▸ Build Settings ▸ "Generate Info.plist File" = No
//         • kida target ▸ Build Settings ▸ "Info.plist File" = Supporting/Info.plist
//    Flow: Secrets.xcconfig → Info.plist `$(VAR)` → the app reads it.

// ── Gemini (cloud VLM — reachable on TestFlight / any network) ──────────────
GEMINI_API_KEY =
GEMINI_MODEL_ID = gemini-2.5-flash

// ── ElevenLabs (the object's spoken voice / TTS) ───────────────────────────
ELEVENLABS_API_KEY =

// ── Mac VLM server (dev). Leave URL empty to skip it and just use Gemini. ──
//    Use your Mac's LAN IP (same Wi-Fi) or an ngrok https URL (works anywhere).
//    IMPORTANT: keep the `/$()/` right after `https:` — a bare `//` is an xcconfig
//    comment and would swallow the rest of the URL.
//    e.g.  VLM_SERVER_URL = https:/$()/abcd-1234.ngrok-free.app
VLM_SERVER_URL =
VLM_SERVER_TOKEN = local-dev-token
VLM_SERVER_TIMEOUT = 30
